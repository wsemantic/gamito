<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Original addons/account/views/report_invoice.xml -->
         <!-- Original addons/account/views/report_invoice.xml -->
        <template id="report_invoice_document_custom" inherit_id="account.report_invoice_document">

            <!-- Mostrar fecha de vencimiento solo para facturas publicadas -->
            <xpath expr="//div[@name='due_date']" position="attributes">
                <attribute name="t-if">o.invoice_date_due and o.move_type in ('out_invoice', 'out_refund') and o.state == 'posted'</attribute>
            </xpath>

            <!-- Añadir el modo de pago junto a la referencia de pago -->
		  <xpath expr="//p[@name='payment_communication']" position="after">
			<p t-if="o.payment_mode_id" class="mt-2">
			  <strong>Método de pago:</strong>
			  <span t-field="o.payment_mode_id.name"/>
			</p>
		  </xpath>

        </template>
        
	   <template id="external_layout_standard_compact_footer"
				  inherit_id="web.external_layout_standard">

			<!-- Variable: True si el pie está vacío o solo tiene HTML vacío -->
			<xpath expr="//div[contains(@t-attf-class, 'footer')]" position="before">
				<t t-set="_footer_is_empty"
				   t-value="not company.report_footer or not company.report_footer.strip() or company.report_footer.strip() in ('&lt;p&gt;&lt;br&gt;&lt;/p&gt;', '&lt;p&gt;&lt;/p&gt;')"/>
			</xpath>

			<!-- Quitar margen inferior del <ul> solo si el pie está vacío -->
			<xpath expr="//div[contains(@t-attf-class, 'footer')]//ul" position="attributes">
				<attribute name="t-attf-class">list-inline {{ 'mb-0' if _footer_is_empty else 'mb4' }}</attribute>
				<attribute name="class"/>
			</xpath>

			<!-- Compactar el contenedor solo si el pie está vacío -->
			<xpath expr="//div[contains(@t-attf-class, 'footer')]//div[hasclass('text-center')]"
				   position="attributes">
				<attribute name="t-attf-style">border-top: 1px solid black; {{ 'padding-top: 2px; line-height: 1.1;' if _footer_is_empty else '' }}</attribute>
			</xpath>

		</template>
